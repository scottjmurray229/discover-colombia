{
	"main": "dist/_worker.js/index.js",
	"name": "discover-colombia",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
"d1_databases": [
    {
      "binding": "DB",
      "database_name": "trip-planner-cache-co2",
      "database_id": "a240bef0-ab44-4665-bf02-f88c559b2182"
    }
  ]
}
